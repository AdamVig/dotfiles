# Validate any candidate command before bootstrap/apply:
# codex execpolicy check --rules config/codex/rules/custom.rules <command> [args...] --pretty
#
# `match` and `not_match` are validation examples (default `[]`). Codex checks
# them when loading rules so mistakes are caught before a rule takes effect.
prefix_rule(
    pattern=["gh", "review-comments"],
    decision="allow",
    match=[["gh", "review-comments", "list"]],
    not_match=[["gh", "pr", "view"]],
)
prefix_rule(
    pattern=["fd"],
    decision="allow",
)

# Python project workflows: allow dependency sync, lock refresh, and common tools.
prefix_rule(
    pattern=["uv", "sync"],
    decision="allow",
)
prefix_rule(
    pattern=["uv", "lock"],
    decision="allow",
)
prefix_rule(
    pattern=["uv", "run", "python"],
    decision="allow",
)
prefix_rule(
    pattern=["uv", "run", "pytest"],
    decision="allow",
)
prefix_rule(
    pattern=["uv", "run", "ruff"],
    decision="allow",
)
prefix_rule(
    pattern=["uv", "run", "ty"],
    decision="allow",
)

prefix_rule(
    pattern=["make"],
    decision="allow",
)
