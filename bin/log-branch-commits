#!/usr/bin/env bash

set -euo pipefail

remote='origin'
branch=
args=()

# If first argument is empty or looks like a flag, use the default branch
if [ -z "${1-}" ] || [[ ${1-} == -* ]]; then
	# In a git-spice stack, use the downstack branch as the base
	if ! branch="$(git-spice down --dry-run 2>/dev/null)"; then
		if ! branch="$(get-default-branch)"; then
			echo 'error: could not get default branch'
			exit 1
		fi
	fi
	args+=("${@:1}")
else
	branch="${1-}"
	args+=("${@:2}")
fi

git log "$remote"/"$branch".. --oneline --pretty=who-when-what "${args[@]}" --
