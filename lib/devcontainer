#!/usr/bin/env bash

# shellcheck source=./lib/helpers
source "${BASH_SOURCE[0]%/*}/helpers"

log() {
	log_with_component devcontainer "$@"
}

cleanup_paths=()
cleanup() {
	if [[ ${#cleanup_paths[@]} == 0 ]]; then
		return
	fi
	rm -rf "${cleanup_paths[@]}" 2>/dev/null
}

trap cleanup EXIT

log_start 'setting up devcontainer'

case "$HOSTTYPE" in
	x86_64)
		copilot_arch=x64
		gnu_arch=x86_64  # codex, git-spice
		kitty_arch=x86_64
		deb_arch=amd64   # also git-who, yq
		;;
	aarch64)
		copilot_arch=arm64
		gnu_arch=aarch64
		kitty_arch=arm64
		deb_arch=arm64
		;;
	*)
		fatal "unsupported arch: $HOSTTYPE"
		;;
esac

log_start 'downloading all packages in parallel'
copilot_tarball="$(mktemp --suffix=.tar.gz)"
codex_zst="$(mktemp --suffix=.zst)"
kitty_tarball="$(mktemp --suffix=.txz)"
git_who_tarball="$(mktemp --suffix=.tar.gz)"
git_spice_tarball="$(mktemp --suffix=.tar.gz)"
yq_bin_file="$(mktemp)"
cleanup_paths+=("$copilot_tarball" "$codex_zst" "$kitty_tarball" "$git_who_tarball" "$git_spice_tarball" "$yq_bin_file")

declare -A downloads=(
	["$(get_release_url 'github/copilot-cli' "copilot-linux-${copilot_arch}.tar.gz")"]="$copilot_tarball"
	["$(get_release_url 'openai/codex' "codex-${gnu_arch}-unknown-linux-musl.zst")"]="$codex_zst"
	["$(get_release_url 'kovidgoyal/kitty' "${kitty_arch}.txz")"]="$kitty_tarball"
	["$(get_release_url 'sinclairtarget/git-who' "_linux_${deb_arch}.tar.gz")"]="$git_who_tarball"
	["$(get_release_url 'abhinav/git-spice' ".Linux-${gnu_arch}.tar.gz")"]="$git_spice_tarball"
	["$(get_release_url 'mikefarah/yq' "linux_${deb_arch}")"]="$yq_bin_file"
)
if command -v apt-get >/dev/null; then
	# Own the dir (711 lets _apt traverse) so the .debs can be chown'd to _apt for apt's sandbox check while we keep
	# delete rights via the parent dir.
	deb_dir="$(mktemp -d)"
	chmod 711 "$deb_dir"
	bat_deb="$deb_dir/bat.deb"
	delta_deb="$deb_dir/delta.deb"
	glow_deb="$deb_dir/glow.deb"
	cleanup_paths+=("$deb_dir")
	downloads+=(
		["$(get_release_url 'sharkdp/bat' "_${deb_arch}.deb")"]="$bat_deb"
		["$(get_release_url 'dandavison/delta' "_${deb_arch}.deb")"]="$delta_deb"
		["$(get_release_url 'charmbracelet/glow' "_${deb_arch}.deb")"]="$glow_deb"
	)
fi

# Single curl invocation downloads everything in parallel
for url in "${!downloads[@]}"; do
	printf 'url = "%s"\noutput = "%s"\n\n' "$url" "${downloads[$url]}"
done | _curl --parallel --parallel-immediate --config -

if command -v apt-get >/dev/null; then
	# Avoid "Download is performed unsandboxed as root" warning from apt-get install
	request_sudo chown _apt:root "$bat_deb" "$delta_deb" "$glow_deb"
fi

copilot_bin_file="$(mktemp)"
codex_bin_file="$(mktemp)"
cleanup_paths+=("$copilot_bin_file" "$codex_bin_file")
tar --extract --gzip --file "$copilot_tarball" --to-stdout >"$copilot_bin_file"
unzstd --stdout "$codex_zst" >"$codex_bin_file"
log_end

if command -v apt-get >/dev/null; then

	declare -a packages=(
		# replacements of default utilities
		"$bat_deb"   # Better cat
		"$delta_deb" # Better git diff
		eza          # Better ls
		fd-find      # Better find
		htop         # Better top
		httpie       # Better curl
		ripgrep      # Better grep

		# command line tools
		fzf         # Fuzzy finder
		"$glow_deb" # Markdown viewer
		tig         # Visual Git client

		ed # Needed by `gh-pr-body-commits`
		emacs-nox
		hunspell       # Needed by Emacs config
		hunspell-en-us # Needed by Emacs config (dictionary)
		kitty-terminfo # For terminal colors
		zsh
	)

	log_start 'installing packages'
	if ! request_sudo env DEBIAN_FRONTEND=noninteractive apt-get install --yes --no-install-recommends "${packages[@]}"; then
		warn 'failed to install apt packages; this may require manual resolution'
	fi
	log_end

	log_start 'linking fdfind to fd'
	mkdir -p "$HOME"/.local/bin
	_ln /usr/bin/fdfind "$HOME"/.local/bin/fd
	log_end
fi

log_start 'installing Copilot'
if ! install --mode='u=rwx,go=rx' "$copilot_bin_file" "$HOME"/.local/bin/copilot; then
	fatal 'failed to install copilot'
fi
log_end

log_start 'installing Codex'
if ! install --mode='u=rwx,go=rx' "$codex_bin_file" "$HOME"/.local/bin/codex; then
	fatal 'failed to install codex'
fi
log_end

log_start 'installing yq'
if ! install --mode='u=rwx,go=rx' "$yq_bin_file" "$HOME"/.local/bin/yq; then
	fatal 'failed to install yq'
fi
log_end

log_start 'installing git-who'
git_who_extracted_tmp="$(extract_tarball_to_tmp "$git_who_tarball")"
cleanup_paths+=("$git_who_extracted_tmp")
install "$git_who_extracted_tmp/linux_${deb_arch}/git-who" "$HOME"/.local/bin/git-who
log_end

log_start 'installing git-spice'
git_spice_extracted_tmp="$(extract_tarball_to_tmp "$git_spice_tarball")"
cleanup_paths+=("$git_spice_extracted_tmp")
install "$git_spice_extracted_tmp"/git-spice "$HOME"/.local/bin/git-spice
git_spice_config_path="$(xdg_config)/git-spice"
mkdir -p "$git_spice_config_path"
echo '{
  "services": {
    "https://github.com": {
      "secrets": {
        "token": {
          "value": "{\"AuthenticationToken\":null,\"github_cli\":true}"
        }
      }
    }
  }
}' >"$git_spice_config_path/secrets.json"
log_end

log_start 'installing kitty'
kitty_extracted_tmp="$(extract_tarball_to_tmp "$kitty_tarball")"
cleanup_paths+=("$kitty_extracted_tmp")
mv "$kitty_extracted_tmp"/bin/kitten "$HOME"/.local/bin
log_end

log 'symlinking Git commit template and attributes'
config_path="$(xdg_config)"/git
mkdir -p "$config_path"
_ln "$script_dir"/../config/git/template "$config_path"/template
_ln "$script_dir"/../config/git/attributes "$config_path"/attributes

log_end
