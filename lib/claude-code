#!/usr/bin/env bash

# shellcheck source=./lib/helpers
source "${BASH_SOURCE[0]%/*}/helpers"

log() {
	log_with_component claude-code "$@"
}

claude_config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"

log_start 'setting up Claude Code'
log_start 'installing'
_curl https://downloads.claude.ai/claude-code-releases/bootstrap.sh | bash
log_end

log_start 'installing settings'
claude_settings_path="$claude_config_dir"/settings.json
existing="$([[ -f $claude_settings_path ]] && cat "$claude_settings_path" || echo '{}')"
# Merge: repo keys win at the top level; object values are merged recursively, preserving keys Claude Code adds itself.
jq --argjson existing "$existing" \
	'$existing * .' \
	"$script_dir"/../config/claude-code-settings.json \
	>"$claude_settings_path"
log_end

log_start 'seeding local CLAUDE.md'
claude_md_path="$claude_config_dir"/CLAUDE.md
if ! [[ -f $claude_md_path ]]; then
	cp "$script_dir"/../config/codex/codex-agents.md "$claude_md_path"

	if is_devcontainer; then
		echo $'\n''You are running inside a Dev Container.' >>"$claude_md_path"
	fi

	log "seeded $claude_md_path"
else
	log "$claude_md_path already exists, skipping seed"
fi
log_end

log_end
