#!/usr/bin/env bash

# shellcheck source=./lib/helpers
source "${BASH_SOURCE[0]%/*}/helpers"

log() {
	log_with_component git "$@"
}

log_start 'setting up Git'

config_path="$(xdg_config)"/git
mkdir -p "$config_path"

log 'symlinking commit template'
_ln "$script_dir"/../config/git/template "$config_path"/template

log 'symlinking attributes'
_ln "$script_dir"/../config/git/attributes "$config_path"/attributes

# If gitconfig does not exist already, create one
if ! [ -e "$config_path"/config ]; then
	log "copying gitconfig to \"$config_path/config\""
	cp "$script_dir"/../config/git/config "$config_path"/config

	log_start 'configuring Git user'
	read -r -p "$(make_prompt 'Full name') " name
	read -r -p "$(make_prompt 'Email address') " email
	read -r -p "$(make_prompt 'GitHub username') " github

	# Only set values if they are non-empty
	[ -n "$name" ] && git config --global user.name "$name"
	[ -n "$email" ] && git config --global user.email "$email"
	[ -n "$github" ] && git config --global github.user "$github"
	log_end
fi

if ! git config --global --includes --get gpg.format >/dev/null; then
	log_start 'migrating commit signing configuration'
	git config unset --global user.signingkey gpg.program gpg.openpgp.program || true
	log_end
fi

log_start 'updating Git configuration'
# Read all values from current Git configuration
git config --list --file "$script_dir"/../config/git/config | while read -r conf_line; do
	# Split line into name and value at equals sign
	IFS='=' read -r name desired_value <<<"$conf_line"

	# shellcheck disable=SC2016
	desired_value="${desired_value/'$XDG_CONFIG_HOME'/$(xdg_config)}"
	# Replace home directory with tilde for readability/portability to Dev Container
	desired_value="${desired_value/#$HOME/\~}"
	current_value="$(git config --global --get "$name" || true)"
	if [ "$current_value" != "$desired_value" ]; then
		log "setting '$name' to '$desired_value'"
		git config --global "$name" "$desired_value"
	fi
done
log_end

log_start 'ensuring SSH allowed signers file exists'
signing_key_path="$HOME/.ssh/id_rsa.pub"
if [ ! -f "$signing_key_path" ]; then
	warn "did not find SSH signing key at \"$signing_key_path\", skipping allowed signers setup"
else
	allowed_signers_path="$config_path/allowed_signers"
	signing_key="$(<"$signing_key_path")"
	if [ ! -f "$allowed_signers_path" ] ||
		! grep --fixed-strings --quiet " $signing_key" "$allowed_signers_path"; then
		log "adding SSH signing key to \"$allowed_signers_path\""
		echo "* $signing_key" >>"$allowed_signers_path"
	fi
	chmod 600 "$allowed_signers_path"
fi
log_end

log_start 'configuring Delta themes'
if ! _curl https://raw.githubusercontent.com/catppuccin/delta/refs/heads/main/catppuccin.gitconfig --output "$config_path"/delta-themes.gitconfig; then
	fatal 'failed to download Delta themes'
fi
# Replace home directory with tilde for readability/portability to Dev Container
git config --global 'include.path' "${config_path/#$HOME/\~}"/delta-themes.gitconfig
log_end

log_end
